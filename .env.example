# Root .env — Docker Compose overrides
# Copy to .env and fill in values. Never commit .env to git.

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=tathastu
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=tathastu_db

# ─── Strapi CMS (apps/cms) ───────────────────────────────────────────────────
DATABASE_URL=postgres://tathastu:change_me_in_prod@postgres:5432/tathastu_db

# Secrets — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=
ADMIN_JWT_SECRET=
API_TOKEN_SALT=
APP_KEYS=key1,key2,key3,key4

# Upload provider (local | aws-s3 | cloudinary)
UPLOAD_PROVIDER=local

# AWS S3 (only needed if UPLOAD_PROVIDER=aws-s3)
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_REGION=
AWS_BUCKET=

# ─── Next.js Frontend (apps/web) ─────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
# Read-only API token — create in Strapi admin → Settings → API Tokens
STRAPI_API_TOKEN=

# Site URL (used for OG tags / sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
