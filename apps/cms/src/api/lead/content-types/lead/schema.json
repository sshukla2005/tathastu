{
  "kind": "collectionType",
  "collectionName": "leads",
  "info": {
    "singularName": "lead",
    "pluralName": "leads",
    "displayName": "Lead",
    "description": "Form submissions from Contact, Demo, and Consultation forms"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": { "type": "string", "required": true },
    "email": { "type": "email", "required": true },
    "phone": { "type": "string" },
    "company": { "type": "string" },
    "message": { "type": "text" },
    "source": {
      "type": "enumeration",
      "enum": ["Contact", "Demo", "Consultation"],
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["New", "Contacted", "Qualified", "Closed"],
      "default": "New"
    }
  }
}
