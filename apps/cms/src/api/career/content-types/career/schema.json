    "type": {
      "type": "enumeration",
      "enum": ["Full-time", "Part-time", "Contract"]
    },
    "department": { "type": "string" },
    "description": { "type": "blocks" },
    "isOpen": { "type": "boolean", "default": true }
  }
}
